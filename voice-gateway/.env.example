# JWT
JWT_SECRET=your-256-bit-secret-at-least-32-chars-long-here
JWT_ALGORITHM=HS256
JWT_EXPIRY_SECONDS=3600

# Redis
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO

# AI Providers (required for voice pipeline)
DEEPGRAM_API_KEY=
OPENAI_API_KEY=
CARTESIA_API_KEY=

# Optional
CARTESIA_VOICE_ID=71a7ad14-091c-4e8e-a314-022ece01c121

# Rate limiting
CONCURRENCY_CAP_PER_USER=2

# Usage quotas (seconds/tokens/chars per user per day)
QUOTA_STT_SECONDS_PER_DAY=1800
QUOTA_LLM_TOKENS_PER_DAY=100000
QUOTA_TTS_CHARS_PER_DAY=250000
